{
  "name": "@localhost-status/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "description": "The macOS desktop app for viewing and terminating listening localhost servers.",
  "author": "Yamparala Rahul",
  "scripts": {
    "dev": "next dev -p 3002",
    "build:web": "next build",
    "start": "next start -p 3002",
    "lint": "eslint .",
    "desktop:dev": "node scripts/dev-desktop.mjs",
    "desktop:prepare": "node scripts/generate-mac-icon.mjs && node scripts/prepare-standalone.mjs",
    "desktop:preview": "npm run build:web && npm run desktop:prepare && electron .",
    "desktop:package": "npm run build:web && npm run desktop:prepare && electron-builder --mac dmg zip"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "agentation": "^2.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "electron": "41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.localhoststatus.app",
    "productName": "Localhost Status",
    "artifactName": "${productName}-${version}-${arch}-mac.${ext}",
    "compression": "maximum",
    "copyright": "Copyright © 2026 Yamparala Rahul",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Localhost Status",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190,
          "type": "file"
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
