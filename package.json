{
  "name": "localhost-status-workspace",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/desktop"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run web:build && npm run desktop:web:build",
    "web:dev": "npm run dev --workspace @localhost-status/web",
    "web:build": "npm run build --workspace @localhost-status/web",
    "web:start": "npm run start --workspace @localhost-status/web",
    "desktop:web:build": "npm run build:web --workspace @localhost-status/desktop",
    "desktop:dev": "npm run desktop:dev --workspace @localhost-status/desktop",
    "desktop:preview": "npm run desktop:preview --workspace @localhost-status/desktop",
    "desktop:build": "npm run desktop:package --workspace @localhost-status/desktop"
  }
}
